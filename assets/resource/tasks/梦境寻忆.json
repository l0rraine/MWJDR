{
    "task": [
        {
            "name": "梦境寻忆",
            "entry": "梦境寻忆_入口",
            "option": [
                "梦境寻忆阶段选择",
                "梦境寻忆模式选择"
            ]
        }
    ],
    "option": {
        "梦境寻忆阶段选择": {
            "type": "input",
            "inputs": [
                {
                    "name": "当前阶段",
                    "pattern_msg": "输入当前阶段",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^\\d+$",
                    "description": "输入当前阶段,0表示最新阶段"
                }
            ],
            "pipeline_override": {
                "梦境寻忆_当前阶段": {
                    "custom_action_param": {
                        "episode": "{当前阶段}"
                    }
                }
            }
        },
        "梦境寻忆模式选择": {
            "type": "select",
            "cases": [
                {
                    "name": "闯关模式",
                    "pipeline_override": {
                        "梦境寻忆_组队": {
                            "enabled": false
                        },
                        "梦境寻忆_闯关": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "协梦同行",
                    "pipeline_override": {
                        "梦境寻忆_组队": {
                            "enabled": true
                        },
                        "梦境寻忆_闯关": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    }
}
