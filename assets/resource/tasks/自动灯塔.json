{
    "task": [
        {
            "name": "自动灯塔",
            "entry": "灯塔入口",
            "option": [
                "灯塔出征队伍设置"
            ]
        }
    ],
    "option": {
        "灯塔出征队伍设置": {
            "type": "input",
            "label": "队伍设置",
            "inputs": [
                {
                    "name": "队伍序号",
                    "pattern_msg": "请输入队伍序号，0表示默认队伍",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^(\\d+)$",
                    "description": "请输入队伍序号，0表示默认队伍"
                }
            ],
            "pipeline_override": {
                "灯塔选择队伍": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "队伍序号": "{队伍序号}"
                            }
                        }
                    }
                }
            }
        }
    }
}
