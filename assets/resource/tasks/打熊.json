{
    "task": [
        {
            "name": "打熊",
            "entry": "熊_入口",
            "option": [
                "打熊-配置"
            ]
        }
    ],
    "option": {
        "打熊-配置": {
            "type": "input",
            "label": "配置",
            "inputs": [
                {
                    "name": "开始时间",
                    "label": "开始时间",
                    "pipeline_type": "string",
                    "default": "20:00",
                    "description": "开始打熊的时间，格式 HH:MM"
                },
                {
                    "name": "大车头",
                    "label": "大车头",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "多个以英文逗号隔开"
                },
                {
                    "name": "小车头",
                    "label": "小车头",
                    "pipeline_type": "string",
                    "default": "",
                    "description": "多个以英文逗号隔开"
                },
                {
                    "name": "循环顺序",
                    "label": "自己的队伍循环顺序",
                    "pipeline_type": "string",
                    "default": "0",
                    "description": "如 0,0,2,2,2，0为默认队伍无需选择"
                }
            ],
            "pipeline_override": {
                "熊_识别队伍": {
                    "custom_action_param": {
                        "开始时间": "{开始时间}",
                        "等待时间": "{等待时间}",
                        "大车头": "{大车头}",
                        "小车头": "{小车头}",
                        "循环顺序": "{循环顺序}"
                    }
                }
            }
        }
    }
}
