{
    "interface_version": 2,
    "name": "MWJDR",
    "github": "https://github.com/l0rraine/MWJDR",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb"
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "{PROJECT_DIR}/resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "{PROJECT_DIR}/python/python.exe",
        "child_args": [
            "-u",
            "{PROJECT_DIR}/../agent/main.py"
        ]
    },
    "task": [],
    "option": {
        "先采联盟矿": {
            "type": "checkbox",
            "label": "先采联盟矿",
            "cases": [
                {
                    "name": "先采联盟矿",
                    "label": "先采联盟矿",
                    "pipeline_override": {
                        "挖矿_参数_联盟矿": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "保留自动加入": {
            "type": "checkbox",
            "label": "保留自动加入",
            "cases": [
                {
                    "name": "保留自动加入",
                    "label": "保留自动加入",
                    "pipeline_override": {
                        "挖矿_参数_保留自动加入": {
                            "enabled": false
                        }
                    }
                }
            ]
        }
    },
    "import": [
        "tasks/自动游历.json",
        "tasks/启动游戏.json",
        "tasks/自动灯塔.json",
        "tasks/集结巨兽.json",
        "tasks/使用物品集结.json",
        "tasks/自动野兽.json",
        "tasks/结束.json",
        "tasks/商店购买.json",
        "tasks/海岛协助打理.json",
        "tasks/联盟总动员.json",
        "tasks/梦境寻忆.json",
        "tasks/打熊.json"
    ]
}
