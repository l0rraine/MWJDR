{
    "task": [
        {
            "name": "商店购买",
            "entry": "商店购买_入口",
            "option": [
                "游荡商人",
                "神秘商店",
                "联盟商店"
            ],
            "doc": "商店购买完成后自动标记，[color:tomato]同日不重复购买[/color]。<br>游荡商人：非钻石物品和统帅经验。<br>神秘商店：免费物品、当季专武和50%折扣物品。<br>联盟商店：统帅经验和75%折扣物品。<br>"
        }
    ],
    "option": {
        "游荡商人": {
            "type": "switch",
            "default_case": "Yes",
            "label": "游荡商人",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "游荡商人_开关": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "游荡商人-钻石刷新次数"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "游荡商人_开关": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "游荡商人-钻石刷新次数": {
            "type": "input",
            "label": "钻石刷新次数",
            "inputs": [
                {
                    "name": "钻石刷新次数",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^\\d+$",
                    "description": "使用钻石刷新游荡商人的次数，0为不使用钻石刷新"
                }
            ],
            "pipeline_override": {
                "游荡商人_刷新控制": {
                    "custom_action_param": {
                        "钻石刷新次数": "{钻石刷新次数}"
                    }
                }
            }
        },
        "神秘商店": {
            "type": "switch",
            "default_case": "Yes",
            "label": "神秘商店",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "神秘商店_开关": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "神秘商店-钻石刷新次数",
                        "神秘商店-当季专武",
                        "神秘商店-宠物自选箱",
                        "神秘商店-高级野性标记",
                        "神秘商店-行军加速",
                        "神秘商店-橙碎"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "神秘商店_开关": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "神秘商店-钻石刷新次数": {
            "type": "input",
            "label": "钻石刷新次数",
            "inputs": [
                {
                    "name": "钻石刷新次数",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^\\d+$",
                    "description": "使用钻石刷新神秘商店的次数，0为不使用钻石刷新"
                }
            ],
            "pipeline_override": {
                "神秘商店_开始购买": {
                    "custom_action_param": {
                        "钻石刷新次数": "{钻石刷新次数}"
                    }
                }
            }
        },
        "神秘商店-当季专武": {
            "type": "checkbox",
            "label": "当季专武 50%",
            "cases": [
                {
                    "name": "神秘商店-当季专武",
                    "label": "当季专武 50%",
                    "pipeline_override": {
                        "神秘商店_参数_当季专武": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "神秘商店-宠物自选箱": {
            "type": "checkbox",
            "label": "宠物自选箱",
            "cases": [
                {
                    "name": "神秘商店-宠物自选箱",
