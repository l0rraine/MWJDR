{
    "task": [
        {
            "name": "集结巨兽",
            "entry": "自动集结_巨兽入口",
            "option": [
                "巨兽队伍设置",
                "19点后使用免费罐头",
                "巨兽作战设置"
            ]
        }
    ],
    "option": {
        "巨兽队伍设置": {
            "type": "input",
            "label": "队伍设置",
            "inputs": [
                {
                    "name": "队伍序号",
                    "pattern_msg": "请输入队伍序号，0表示默认队伍",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^(\\d+)$",
                    "description": "请输入队伍序号，0表示默认队伍"
                }
            ],
            "pipeline_override": {
                "自动集结_选择队伍": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "队伍序号": "{队伍序号}"
                            }
                        }
                    }
                }
            }
        },
        "19点后使用免费罐头": {
            "type": "switch",
            "label": "19点后使用免费罐头",
            "description": "打开时，19点后可以使用免费罐头",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "自动集结_使用19点罐头": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {}
                }
            ]
        },
        "巨兽作战设置": {
            "type": "switch",
            "label": "作战设置",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {},
                    "option": [
                        "巨兽作战-只执行10次"
                    ]
                },
                {
                    "name": "Yes",
                    "option": [
                        "巨兽作战高级设置"
                    ]
                }
            ],
            "description": "关闭时为普通模式，清空所有体力集结，打开时为高级模式"
        },
        "巨兽作战-只执行10次": {
            "type": "switch",
            "default_case": "No",
            "label": "只执行10次",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "自动集结_准备出征": {
                            "custom_action_param": {
                                "高级模式": 0,
                                "出征次数": "10",
                                "使用物品": 0,
                                "罐头数量": 0
                            }
                        },
                        "自动集结_查看次数": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {}
                }
            ],
            "description": "每天只打10次巨兽，打完停止"
        },
        "巨兽作战高级设置": {
            "type": "switch",
            "label": "高级设置",
            "cases": [
                {
                    "name": "No",
                    "option": [
                        "巨兽次数设置-精确次数"
                    ]
                },
                {
                    "name": "Yes",
                    "option": [
                        "巨兽体力设置-罐头个数"
                    ]
                }
            ],
            "description": "打开时为体力模式，关闭为次数模式"
        },
        "巨兽体力设置-罐头个数": {
            "type": "input",
            "inputs": [
                {
                    "name": "使用罐头个数",
                    "pattern_msg": "输入罐头个数",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^\\d+$",
                    "description": "输入罐头个数"
                }
            ],
            "pipeline_override": {
                "自动集结_准备出征": {
                    "custom_action_param": {
                        "高级模式": 1,
                        "出征次数": 0,
                        "使用物品": 0,
                        "罐头数量": "{使用罐头个数}"
                    }
                }
            }
        },
        "巨兽次数设置-精确次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "战斗次数",
                    "pattern_msg": "输入打巨兽的次数，最多4位",
                    "pipeline_type": "string",
                    "default": "0",
                    "verify": "^[1-9]\\d{0,3}$",
                    "description": "输入打巨兽的次数，最多4位"
                }
            ],
            "pipeline_override": {
                "自动集结_准备出征": {
                    "custom_action_param": {
                        "高级模式": 1,
                        "出征次数": "{战斗次数}",
                        "使用物品": 0,
                        "罐头数量": 0
                    }
                }
            }
        }
    }
}
